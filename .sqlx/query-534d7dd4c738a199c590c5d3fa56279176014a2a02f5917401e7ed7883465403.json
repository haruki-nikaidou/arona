{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                id,\n                conversation_id,\n                before,\n                role AS \"role: MessageRole\",\n                created_at,\n                is_current_branch\n            FROM memory.conversation_message\n            WHERE conversation_id = $1\n              AND (NOT $2 OR is_current_branch)\n            ORDER BY created_at ASC\n            LIMIT $3 OFFSET $4\n            ",
