  "query": "\n            SELECT\n                id,\n                identity,\n                story_type AS \"story_type: StoryType\",\n                story_name,\n                story_summary,\n                story_text,\n                happened_at,\n                related_conversation\n            FROM memory.contact_story\n            WHERE identity = $1\n            ORDER BY happened_at DESC\n            LIMIT $2 OFFSET $3\n            ",
